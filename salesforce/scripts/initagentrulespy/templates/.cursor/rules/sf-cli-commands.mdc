sf logic run test --test-category Apex --test-category Flow -l RunLocalTests -y -c -o {{ORG_ALIAS}}
sf logic run test -n MyApexClassTest.methodA -n MyApexClassTest.methodB -s MySuite -o {{ORG_ALIAS}}
sf logic run test -r junit -d ./test-results -y -c -o {{ORG_ALIAS}}
sf logic get test --test-run-id <id> -o {{ORG_ALIAS}}
sf logic get test -i <id> -o {{ORG_ALIAS}} -c -v -r human                                  # Detailed coverage
```

