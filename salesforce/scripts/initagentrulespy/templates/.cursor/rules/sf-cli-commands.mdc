### Login / Logout
```bash
sf org login web -a {{ORG_ALIAS}}                                 # Browser-based OAuth; default flow
sf org login web -a {{ORG_ALIAS}} -r https://test.salesforce.com  # Sandbox login (-r ≡ --instance-url)
sf org login web -a {{ORG_ALIAS}} -s -d                           # Set as default and default-dev-hub
sf org login jwt --client-id <id> --jwt-key-file server.key --username <u> -a {{ORG_ALIAS}}
sf org login jwt -i <client-id> -f server.key -o <username> -a {{ORG_ALIAS}}           # Short form
sf org login sfdx-url -f auth-url.txt -a {{ORG_ALIAS}}            # Auth via stored SFDX URL file
sf org login sfdx-url -u "$AUTH_URL" -a {{ORG_ALIAS}}             # Pipe URL via stdin
sf org login access-token -r https://mycompany.my.salesforce.com -a {{ORG_ALIAS}}      # Token via $SF_ACCESS_TOKEN
# Link an external client app to an authenticated user (Agentforce client-app workflow)
sf org login web -c MyClientApp --username me@example.com --scopes "sfap_api chatbot_api"
sf org logout -o {{ORG_ALIAS}}                                    # Single org
sf org logout -a --no-prompt                                # All orgs (-a ≡ --all)
sf org logout -c MyClientApp -o me@example.com              # Logout of a specific client-app link only
```

